# Valor por defecto (puedes sobreescribir con --dart-define=API_BASE_URL=...)
# Simulador iOS / escritorio: http://localhost:3000
# Emulador Android: http://10.0.2.2:3000 (localhost del host)
# Dispositivo físico: http://<IP-LAN-de-tu-PC>:3000
API_BASE_URL=http://localhost:3000

