# Uncomment this line to define a global platform for your project
platform :ios, '13.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= ['$(inherited)']
      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] += [
        'PERMISSION_PHOTOS=1',
        'PERMISSION_LOCATION=0',
        'PERMISSION_LOCATION_WHENINUSE=1',
      ]
    end
  end

  # codesign falla con "resource fork / Finder information not allowed" cuando el proyecto
  # vive bajo ~/Documents (iCloud) o tiene metadatos de Finder. Limpia xattrs antes de firmar.
  phase_name = '[CP] Strip xattrs (CodeSign)'
  shell_script = <<~'SCRIPT'.strip
    # Limpiar xattrs del BUILT_PRODUCTS_DIR completo antes de CodeSign
    if [ -n "${BUILT_PRODUCTS_DIR:-}" ] && [ -d "${BUILT_PRODUCTS_DIR}" ]; then
      /usr/bin/xattr -cr "${BUILT_PRODUCTS_DIR}" 2>/dev/null || true
    fi
    # Limpiar xattrs del TARGET_BUILD_DIR específico
    if [ -n "${TARGET_BUILD_DIR:-}" ] && [ -d "${TARGET_BUILD_DIR}" ]; then
      /usr/bin/xattr -cr "${TARGET_BUILD_DIR}" 2>/dev/null || true
    fi
    # Limpiar frameworks específicamente
    if [ -n "${TARGET_BUILD_DIR:-}" ] && [ -d "${TARGET_BUILD_DIR}" ]; then
      /usr/bin/find "${TARGET_BUILD_DIR}" -name "*.framework" -type d 2>/dev/null | while IFS= read -r fw; do
        /usr/bin/xattr -cr "$fw" 2>/dev/null || true
      done
    fi
  SCRIPT

  installer.pods_project.targets.each do |target|
    next unless target.is_a?(Xcodeproj::Project::Object::PBXNativeTarget)
    # Evitar duplicados si cambia la posición del script.
    target.build_phases.delete_if { |p| p.respond_to?(:name) && p.name == phase_name }

    phase = installer.pods_project.new(Xcodeproj::Project::Object::PBXShellScriptBuildPhase)
    phase.name = phase_name
    phase.shell_script = shell_script
    phase.show_env_vars_in_log = '0'
    # IMPORTANTE: debe ejecutarse ANTES de CodeSign, por eso input_paths y output_paths vacíos
    phase.input_paths = []
    phase.output_paths = []
    # Insertar ANTES de CodeSign (normalmente después de Compile/Link pero antes de Sign)
    # Lo insertamos al principio de build_phases para asegurar que se ejecute temprano
    target.build_phases.insert(0, phase)
  end
  installer.pods_project.save
end
