# URL base del backend (sin /api al final).
#
# La app carga por defecto [assets/config/environment.env].
# Para desarrollo local puedes editar ese archivo, o usar:
#   flutter run --dart-define=API_BASE_URL=http://10.0.2.2:3000
#
# iOS simulador / desktop: localhost
# Android emulador (Mac host): use 10.0.2.2 en lugar de localhost
# Dispositivo físico: IP de tu Mac en la LAN
API_BASE_URL=http://localhost:3000

